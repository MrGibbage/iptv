// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "org.pelorus.iptv",
  "asar": true,
  // Native Node addons cannot load from inside app.asar. Explicit rules make
  // this reliable even if electron-builder's automatic smart-unpack changes.
  "asarUnpack": [
    "node_modules/electron-libmpv/**",
    "node_modules/better-sqlite3/**"
  ],
  "productName": "IPTV Viewer",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  // Windows' DLL loader searches beside the executable. electron-libmpv is
  // imported during main-process startup, so libmpv must be available there.
  "extraFiles": [
    {
      "from": "libmpv-2.dll",
      "to": "libmpv-2.dll"
    }
  ],
  "win": {
    // Keep private-beta builds unsigned for now. This also avoids extracting
    // electron-builder's cross-platform signing bundle, whose unused macOS
    // symlinks require Windows Developer Mode or an elevated shell.
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
